API_KEY=change_me_to_a_long_random_string

# sqlite:///./otp.db для локальной разработки
# В проде — управляемая PostgreSQL Timeweb (отдельная база otp_service
# на том же кластере, что и beauty_platform):
# postgresql+psycopg2://user:password@<host из панели Timeweb>:5432/otp_service
DATABASE_URL=sqlite:///./otp.db

OTP_LENGTH=4
OTP_TTL_MINUTES=5
MAX_VERIFY_ATTEMPTS=3
RATE_LIMIT_PER_MINUTE=3

# mock | live  (mock печатает код в лог, ничего не отправляет)
SMS_MODE=mock

SMSC_LOGIN=
SMSC_PASSWORD=
SMSC_SENDER_ID=

SMSRU_API_ID=
